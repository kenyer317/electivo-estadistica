   "cell_type": "code",
   "execution_count": 244,
   "id": "53b1e528",
   "metadata": {},
   "outputs": [
    {
     "data": {
      "text/plain": [
       "   colores frecuencias frecuencias_relativas frecuencias_acumuladas\n",
       "1 Amarillo           2               9.52381                      2\n",
       "2     Azul           5              23.80952                      7\n",

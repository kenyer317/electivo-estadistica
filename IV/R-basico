   "source": [
    "## Tabla de frecuencias relativas\n",
    "$$Frel = \\frac{\\text{Frec}}{\\text{Número de datos}}*100$$"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 242,
   "id": "7ed9a2ae",
   "metadata": {},
   "outputs": [
    {
     "data": {
      "text/plain": [
       "color\n",
       "Amarillo     Azul     Café  Naranja     Rojo    Verde \n",
